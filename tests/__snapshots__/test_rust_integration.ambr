# name: TestRustMinifier.test_minification_snapshot[rust_minified_size_constrained]
  '''
  use std::io::{self,BufRead};
  const GRID_SIZE:usize=10;
  const MAX_MOVES:usize=100;
  fn main(){
  let stdin=io::stdin();
  let mut lines=stdin.lock().lines();
  let first_line=lines.next().unwrap().unwrap();
  let dimensions:Vec<usize>=first_line
  .split_whitespace()
  .map(|s|s.parse().unwrap())
  .collect();
  let width=dimensions[0];
  let height=dimensions[1];
  let mut grid:Vec<Vec<i32>>=Vec::with_capacity(height);
  for _ in 0..height{
  let line=lines.next().unwrap().unwrap();
  let row:Vec<i32>=line
  .split_whitespace()
  .map(|s|s.parse().unwrap())
  .collect();
  grid.push(row);
  }
  let mut result=0;
  for y in 0..height{
  for x in 0..width{
  if x>0{result+=grid[y][x-1];}
  if x<width-1{result+=grid[y][x+1];}
  if y>0{result+=grid[y-1][x];}
  if y<height-1{result+=grid[y+1][x];}
  }
  }
  println!("{}",result);
  let _debug_msg="// This is not a comment, it's a string literal";
  let _another="/* Also not a comment */";
  }
  '''
